# NexusX Backend Configuration
# Copy this to .env on your VPS and fill in real values

# Server
PORT=4000
NODE_ENV=production

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Database
DB_PATH=./data/nexus.db

# CORS — your frontend origin
CORS_ORIGIN=https://yourdomain.com

# Default admin (created on first DB init)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# ============================================================
# AccHub Provider — uses website login (sms.acchub.io)
# ============================================================
ACCHUB_BASE_URL=https://sms.acchub.io
ACCHUB_USERNAME=ShovonYE
ACCHUB_PASSWORD=your_acchub_password_here

# ============================================================
# IMS Provider — Puppeteer browser bot (no API)
# Bot logs into imssms.org panel and scrapes numbers + OTPs.
# ============================================================
IMS_ENABLED=true
IMS_BASE_URL=https://www.imssms.org
IMS_USERNAME=Shovonkhan7
IMS_PASSWORD=your_ims_password_here
# Path to Chromium/Chrome on the VPS. Leave blank to use puppeteer's bundled chromium.
# Ubuntu install: sudo apt-get install -y chromium-browser
# Then set: IMS_CHROME_PATH=/usr/bin/chromium-browser
IMS_CHROME_PATH=
# How often the bot scrapes IMS (seconds). Lower = faster OTP detection but more CPU.
IMS_SCRAPE_INTERVAL=8
# Run browser headless (true on VPS, false only when debugging locally)
IMS_HEADLESS=true

# ============================================================
# MSI Provider — Puppeteer browser bot (no API)
# Bot logs into 145.239.130.45/ints panel and scrapes numbers + OTPs.
# Same Chromium binary as IMS works fine.
# ============================================================
MSI_ENABLED=true
MSI_BASE_URL=http://145.239.130.45
MSI_USERNAME=Ashik07
MSI_PASSWORD=your_msi_password_here
# Reuse the same Chromium binary as IMS — leave blank to use puppeteer's bundled one.
MSI_CHROME_PATH=
# OTP poll interval (seconds). MSI has NO 15s rate-limit so we can scrape fast.
MSI_SCRAPE_INTERVAL=5
# How often the bot re-syncs the number pool (seconds). Default 10min.
MSI_NUMBERS_INTERVAL=600
# Run browser headless (true on VPS)
MSI_HEADLESS=true

# OTP polling interval for AccHub (seconds)
OTP_POLL_INTERVAL=5

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
